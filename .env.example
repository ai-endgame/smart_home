# Copy this file to .env and fill in your values.
# The server loads .env automatically on startup.

# PostgreSQL connection string.
# Without this the server runs in-memory only (devices lost on restart).
DATABASE_URL=postgres://user:password@localhost/smart_home

# Optional: override the default bind address (127.0.0.1:8080).
# SMART_HOME_SERVER_ADDR=0.0.0.0:8080

# Optional: adjust log levels.
# RUST_LOG=smart_home=debug
# RUST_LOG=mdns_sd=debug   # re-enable suppressed mDNS internal logs
